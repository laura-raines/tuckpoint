# Copy to .env.local and fill in. Never commit .env.local.

# Chicago open data (data.cityofchicago.org → free app token)
SOCRATA_APP_TOKEN=

# Anthropic — server-side only, never exposed to the client
ANTHROPIC_API_KEY=

# Firebase Admin: either a service-account JSON blob here, or leave unset and
# use GOOGLE_APPLICATION_CREDENTIALS / gcloud application-default login.
FIREBASE_SERVICE_ACCOUNT=
