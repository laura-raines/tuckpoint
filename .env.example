# Copy to .env.local and fill in. Never commit .env.local.

# Chicago open data (data.cityofchicago.org → free app token)
SOCRATA_APP_TOKEN=

# Anthropic — server-side only, never exposed to the client
ANTHROPIC_API_KEY=

# Firebase Admin — pick ONE:
# (a) download a service-account key (Firebase console → Project settings →
#     Service accounts → Generate new private key), save it as
#     service-account.json in the repo root (gitignored), and set:
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# (b) or paste the whole key JSON on one line (single-quoted) — needed on Vercel:
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'
